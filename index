<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Untuk Sayangku</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            background-color: #ffebee;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            overflow: hidden;
        }

        .container {
            text-align: center;
            background: rgba(255, 255, 255, 0.9);
            padding: 30px;
            border-radius: 20px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            z-index: 2;
            width: 80%;
            max-width: 400px;
        }

        h1 {
            color: #d81b60;
            font-size: 1.5rem;
            margin-bottom: 20px;
            line-height: 1.4;
        }

        .heart-main {
            color: #e91e63;
            font-size: 60px;
            animation: beat 0.8s infinite alternate;
            margin-bottom: 10px;
        }

        @keyframes beat {
            to { transform: scale(1.2); }
        }

        .heart-drop {
            position: absolute;
            top: -10%;
            z-index: 1;
            user-select: none;
            pointer-events: none;
            animation: fall linear forwards;
        }

        @keyframes fall {
            to {
                transform: translateY(110vh) rotate(360deg);
            }
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="heart-main">❤️</div>
        <h1>aku sayang banget sama kamu sayang</h1>
        <p style="color: #888; font-size: 0.9rem;">Selamanya dan seterusnya ✨</p>
    </div>

    <script>
        function createHeart() {
            const heart = document.createElement('div');
            heart.classList.add('heart-drop');
            heart.innerHTML = '❤️';
            
            // Posisi acak
            heart.style.left = Math.random() * 100 + 'vw';
            
            // Ukuran acak
            const size = Math.random() * 20 + 10 + 'px';
            heart.style.fontSize = size;
            
            // Kecepatan jatuh acak
            const duration = Math.random() * 3 + 2 + 's';
            heart.style.animationDuration = duration;
            
            // Transparansi acak
            heart.style.opacity = Math.random() * 0.5 + 0.5;
            
            document.body.appendChild(heart);

            // Hapus elemen setelah jatuh agar HP tidak lemot
            setTimeout(() => {
                heart.remove();
            }, 5000);
        }

        // Munculkan hati setiap 300 milidetik
        setInterval(createHeart, 300);
    </script>
</body>
</html>
